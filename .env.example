# 复制此文件为仓库根目录下的 .env 并填入你的值

# 阿里百炼 DashScope
DASHSCOPE_API_KEY=sk-your-api-key
DASHSCOPE_API_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenAI 兼容接口
OPENAI_API_KEY=sk-your-api-key
OPENAI_API_HOST=https://your-openai-compatible-gateway
OPENAI_MODEL=gpt-5-mini

# DeepSeek
DEEPSEEK_API_KEY=sk-your-api-key
DEEPSEEK_API_HOST=https://api.deepseek.com
DEEPSEEK_BETA_API_HOST=https://api.deepseek.com/beta
DEEPSEEK_MODEL=deepseek-v4-flash

# MiniMax
MINIMAX_API_KEY=sk-your-api-key
MINIMAX_API_HOST=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7

# Hugging Face Hub token，用于提高公开模型下载速率限制
HF_TOKEN=hf_your_token

# 火山方舟
VOLCANO_API_KEY=your-volcano-api-key
VOLCANO_API_HOST=https://ark.cn-beijing.volces.com/api/coding/v3
VOLCANO_MODEL=deepseek-v4-flash
